generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = "DATABASE_URL"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())
  memberships Membership[]
  goals       Goal[]
  tasks       Task[]
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String
  createdAt   DateTime @default(now())
  members Membership[]
  goals   Goal[]
  posts   Announcement[]
  tasks   Task[]
}

model Membership {
  id String @id @default(cuid())
  userId      String
  workspaceId String
  role        String
  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
}

model Goal {
  id      String    @id @default(cuid())
  title   String
  status  String
  dueDate DateTime?
  ownerId     String
  workspaceId String
  owner     User      @relation(fields: [ownerId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  milestones Milestone[]
  tasks      Task[]
}

model Milestone {
  id       String @id @default(cuid())
  title    String
  progress Int
  goalId String
  goal   Goal   @relation(fields: [goalId], references: [id])
}

model Announcement {
  id      String  @id @default(cuid())
  title   String
  content String
  pinned  Boolean @default(false)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Task {
  id       String    @id @default(cuid())
  title    String
  priority String
  status   String
  dueDate  DateTime?
  assigneeId  String?
  workspaceId String
  goalId      String?
  assignee  User?     @relation(fields: [assigneeId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  goal      Goal?     @relation(fields: [goalId], references: [id])
}
